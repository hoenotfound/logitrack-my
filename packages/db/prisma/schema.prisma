// packages/db/prisma/schema.prisma
// LogiTrack MY — Core Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// MULTI-TENANCY
// ─────────────────────────────────────────────
model Tenant {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  sstRegNo      String?   // SST registration
  rocNo         String?   // ROC / SSM registration
  billingEmail  String
  plan          Plan      @default(STARTER)
  createdAt     DateTime  @default(now())

  users         User[]
  orders        Order[]
  shipments     Shipment[]
  warehouses    Warehouse[]
  vehicles      Vehicle[]
  invoices      Invoice[]
  customsDecl   CustomsDeclaration[]
}

enum Plan {
  STARTER
  GROWTH
  ENTERPRISE
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────
model User {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  email        String    @unique
  name         String
  phone        String?
  role         UserRole  @default(OPS)
  passwordHash String
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?

  assignedOrders   Order[]       @relation("AssignedDriver")
  createdOrders    Order[]       @relation("CreatedBy")
  trackingEvents   TrackingEvent[]
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPS
  DRIVER
  CUSTOMER
  FINANCE
}

// ─────────────────────────────────────────────
// CUSTOMERS (B2B shippers)
// ─────────────────────────────────────────────
model Customer {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  email       String
  phone       String
  companyReg  String?  // SSM number
  sstNo       String?
  addresses   Address[]
  orders      Order[]
  createdAt   DateTime @default(now())
}

model Address {
  id          String   @id @default(cuid())
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  label       String?  // e.g. "Warehouse A", "HQ"
  line1       String
  line2       String?
  postcode    String
  city        String
  state       MalaysiaState
  country     String   @default("MY")
  lat         Float?
  lng         Float?

  pickupOrders   Order[] @relation("PickupAddress")
  deliveryOrders Order[] @relation("DeliveryAddress")
}

enum MalaysiaState {
  JOHOR
  KEDAH
  KELANTAN
  MELAKA
  NEGERI_SEMBILAN
  PAHANG
  PENANG
  PERAK
  PERLIS
  SABAH
  SARAWAK
  SELANGOR
  TERENGGANU
  KUALA_LUMPUR
  LABUAN
  PUTRAJAYA
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────
model Order {
  id             String      @id @default(cuid())
  orderNo        String      @unique  // LT-2024-00001
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  customerId     String
  customer       Customer    @relation(fields: [customerId], references: [id])
  createdById    String
  createdBy      User        @relation("CreatedBy", fields: [createdById], references: [id])
  assignedToId   String?
  assignedTo     User?       @relation("AssignedDriver", fields: [assignedToId], references: [id])

  type           OrderType
  status         OrderStatus @default(PENDING)
  priority       Priority    @default(NORMAL)

  pickupAddressId   String
  pickupAddress     Address  @relation("PickupAddress", fields: [pickupAddressId], references: [id])
  deliveryAddressId String
  deliveryAddress   Address  @relation("DeliveryAddress", fields: [deliveryAddressId], references: [id])

  scheduledPickup  DateTime?
  scheduledDelivery DateTime?
  actualPickup     DateTime?
  actualDelivery   DateTime?

  items          OrderItem[]
  shipment       Shipment?
  trackingEvents TrackingEvent[]
  invoice        Invoice?
  podPhoto       String?          // S3 key
  podSignature   String?          // S3 key
  notes          String?
  internalNotes  String?

  codAmount      Decimal?  @db.Decimal(10,2)  // Cash on delivery
  declaredValue  Decimal?  @db.Decimal(10,2)
  insurance      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

enum OrderType {
  LAST_MILE
  FREIGHT
  WAREHOUSE_IN
  WAREHOUSE_OUT
  CROSS_BORDER
  RETURN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PICKED_UP
  IN_TRANSIT
  AT_WAREHOUSE
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED_ATTEMPT
  RETURNED
  CANCELLED
}

enum Priority {
  EXPRESS
  NORMAL
  ECONOMY
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  description String
  hsCode      String?  // for customs
  qty         Int
  unitWeight  Float    // kg
  length      Float?   // cm
  width       Float?   // cm
  height      Float?   // cm
  unitValue   Decimal  @db.Decimal(10,2)
}

// ─────────────────────────────────────────────
// SHIPMENTS (freight / multi-leg)
// ─────────────────────────────────────────────
model Shipment {
  id           String   @id @default(cuid())
  awbNo        String   @unique   // Air/Sea waybill
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  orderId      String   @unique
  order        Order    @relation(fields: [orderId], references: [id])

  mode         ShipmentMode
  carrier      String?
  vesselFlight String?
  etd          DateTime?
  eta          DateTime?
  atd          DateTime?
  ata          DateTime?

  origin       String
  destination  String
  status       ShipmentStatus @default(BOOKING)

  legs         ShipmentLeg[]
  customsDecl  CustomsDeclaration?
  createdAt    DateTime @default(now())
}

enum ShipmentMode {
  ROAD
  AIR
  SEA
  RAIL
  MULTIMODAL
}

enum ShipmentStatus {
  BOOKING
  CONFIRMED
  LOADED
  IN_TRANSIT
  ARRIVED
  CUSTOMS
  RELEASED
  DELIVERED
}

model ShipmentLeg {
  id          String   @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id])
  sequence    Int
  mode        ShipmentMode
  from        String
  to          String
  vehicleId   String?
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  departedAt  DateTime?
  arrivedAt   DateTime?
}

// ─────────────────────────────────────────────
// WAREHOUSING
// ─────────────────────────────────────────────
model Warehouse {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  code      String   @unique
  address   String
  state     MalaysiaState
  totalArea Float    // sqm
  zones     Zone[]
  createdAt DateTime @default(now())
}

model Zone {
  id          String   @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  name        String
  type        ZoneType
  bins        Bin[]
}

enum ZoneType {
  INBOUND
  OUTBOUND
  STORAGE
  COLD_CHAIN
  HAZMAT
  RETURNS
}

model Bin {
  id       String  @id @default(cuid())
  zoneId   String
  zone     Zone    @relation(fields: [zoneId], references: [id])
  code     String  // e.g. "A-01-03"
  capacity Float   // cubic metres
  stocks   Stock[]
}

model Stock {
  id         String   @id @default(cuid())
  binId      String
  bin        Bin      @relation(fields: [binId], references: [id])
  sku        String
  description String
  qty        Int
  batchNo    String?
  expiryDate DateTime?
  updatedAt  DateTime @updatedAt
}

// ─────────────────────────────────────────────
// FLEET
// ─────────────────────────────────────────────
model Vehicle {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  plate        String   @unique
  type         VehicleType
  maxPayload   Float    // kg
  maxVolume    Float    // cubic metres
  fuelType     String   @default("petrol")
  puspakomExp  DateTime? // Malaysia roadworthiness expiry
  insuranceExp DateTime?
  legs         ShipmentLeg[]
  liveLocation VehicleLocation?
  createdAt    DateTime @default(now())
}

enum VehicleType {
  MOTORCYCLE
  VAN
  LORRY_1T
  LORRY_3T
  LORRY_5T
  LORRY_10T
  CONTAINER_20FT
  CONTAINER_40FT
}

model VehicleLocation {
  id        String   @id @default(cuid())
  vehicleId String   @unique
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  lat       Float
  lng       Float
  speed     Float?
  heading   Float?
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// TRACKING
// ─────────────────────────────────────────────
model TrackingEvent {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  status    OrderStatus
  message   String
  lat       Float?
  lng       Float?
  photo     String?     // S3 key
  createdAt DateTime    @default(now())
}

// ─────────────────────────────────────────────
// CUSTOMS (cross-border)
// ─────────────────────────────────────────────
model CustomsDeclaration {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  shipmentId   String   @unique
  shipment     Shipment @relation(fields: [shipmentId], references: [id])
  declarationType String  // K1, K2, K8, K9
  exportCountry   String
  importCountry   String
  totalValue      Decimal @db.Decimal(12,2)
  currency        String  @default("MYR")
  incoterms       String  // FOB, CIF, EXW
  status          CustomsStatus @default(DRAFT)
  submittedAt     DateTime?
  approvedAt      DateTime?
  customsRef      String?
  dutyAmount      Decimal? @db.Decimal(10,2)
  createdAt       DateTime @default(now())
}

enum CustomsStatus {
  DRAFT
  SUBMITTED
  QUERIED
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// BILLING
// ─────────────────────────────────────────────
model Invoice {
  id           String        @id @default(cuid())
  invoiceNo    String        @unique   // INV-2024-00001
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  orderId      String?       @unique
  order        Order?        @relation(fields: [orderId], references: [id])
  subtotal     Decimal       @db.Decimal(10,2)
  sstAmount    Decimal       @db.Decimal(10,2)  // 8% SST
  total        Decimal       @db.Decimal(10,2)
  currency     String        @default("MYR")
  status       InvoiceStatus @default(DRAFT)
  dueDate      DateTime
  paidAt       DateTime?
  paymentRef   String?       // FPX / DuitNow ref
  pdfKey       String?       // S3 key
  lineItems    InvoiceLineItem[]
  createdAt    DateTime      @default(now())
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  description String
  qty         Int
  unitPrice   Decimal @db.Decimal(10,2)
  total       Decimal @db.Decimal(10,2)
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  VOID
}
