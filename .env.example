# ─────────────────────────────────────────────
# LogiTrack MY — Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://logitrack:password@localhost:5432/logitrack_my"
# REDIS_URL="redis://localhost:6379"  ← DISABLED: using in-memory EventEmitter for MVP

# ── Auth (NextAuth.js) ────────────────────────
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ── File Storage (Cloudflare R2 or AWS S3) ────
S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
S3_BUCKET="logitrack-media"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="auto"

# ── WhatsApp (Meta Cloud API / 360dialog) ─────
WA_API_URL="https://waba.360dialog.io/v1"
WA_API_TOKEN=""
WA_PHONE_NUMBER_ID=""

# ── Email (Postmark) ──────────────────────────
POSTMARK_TOKEN=""
POSTMARK_FROM="noreply@logitrack.my"

# ── Payment ───────────────────────────────────
# Billplz (Malaysia FPX)
BILLPLZ_API_KEY=""
BILLPLZ_COLLECTION_ID=""
# DuitNow QR (via Stripe MY or direct bank API)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Maps & Routing ────────────────────────────
GOOGLE_MAPS_API_KEY=""
# OSRM self-hosted (optional — uses public OSRM if unset)
OSRM_URL="http://localhost:5000"

# ── Customs (JKDM uCustoms API) ──────────────
JKDM_API_URL="https://ucustoms.customs.gov.my/api/v1"
JKDM_API_KEY=""

# ── Feature Flags ─────────────────────────────
ENABLE_COD=true
ENABLE_CROSS_BORDER=true
ENABLE_WAREHOUSE=true
ENABLE_ROUTE_OPTIMIZER=true
NEXT_PUBLIC_TRACKING_URL="https://track.logitrack.my"
